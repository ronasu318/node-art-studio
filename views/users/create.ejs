<div class="container">
    <h2>➕ 新增成員</h2>
    <form action="/users/add" method="POST" class="styled-form">
        <div class="form-group">
            <label>姓名</label>
            <input type="text" name="name" placeholder="請輸入姓名" required>
        </div>
        <div class="form-group">
            <label>電子郵件</label>
            <input type="email" name="email" placeholder="example@mail.com" required>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">儲存資料</button>
            <a href="/users" class="btn-secondary">取消並返回</a>
        </div>
    </form>
</div>